# ============================================================
# RAG Retrieval Agent - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your Azure credentials.
# NEVER commit your actual .env file to the repository.
# ============================================================

# Azure OpenAI credentials (required for embeddings + LLM)
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Azure deployment names (match your Azure portal deployment names)
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5.1

# Token pricing (USD per 1K tokens) for usage cost estimation
# Fill these with your Azure pricing for the deployed models.
AZURE_CHAT_INPUT_COST_PER_1K=0.00125
AZURE_CHAT_OUTPUT_COST_PER_1K=0.011
AZURE_EMBEDDING_INPUT_COST_PER_1K=0.00125

# ============================================================
# Azure Computer Vision API (optional - for image processing)
# ============================================================
# Leave empty to skip image processing or provide both endpoint and key

# Azure Vision endpoint for image analysis
AZURE_VISION_ENDPOINT=https://your-vision-resource.cognitiveservices.azure.com/
# Azure Vision API key
AZURE_VISION_API_KEY=your-vision-api-key-here

# ============================================================
# Image Processing Options (optional)
# ============================================================
# Enable OCR fallback for scanned PDFs (expensive, set to 1 to enable)
ENABLE_OCR_FALLBACK=0
